                "from_value": 1.2,
                "to_value": -1
              },
              "argument2": {
                "type": "minecraft:mul",
                "argument1": 0.55,
                "argument2": "minecraft:overworld/base_3d_noise"
              }
            }
          }
        }
      }
    },
    "fluid_level_floodedness": 0,
    "fluid_level_spread": 0,
